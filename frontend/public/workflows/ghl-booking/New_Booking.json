{
  "name": "New Booking from GoHighLevel",
  "description": "Receives a booking webhook from GoHighLevel, fetches appointment details from GHL, finds or creates the lead, and syncs the booking to 1Prompt.",
  "trigger_type": "inbound_webhook",
  "nodes": [
    {
      "id": "trigger-1",
      "type": "trigger",
      "label": "Receive New Booking",
      "trigger_type": "inbound_webhook",
      "position": { "x": 300, "y": 50 },
      "config": {}
    },
    {
      "id": "action-fetch-appt",
      "type": "action",
      "label": "Fetch Appointment",
      "position": { "x": 300, "y": 200 },
      "config": {
        "action_type": "api_call",
        "icon": "calendar",
        "description": "Fetch appointment details from GHL API using Booking ID",
        "endpoint": "GET /calendars/events/{{trigger.Booking_ID}}",
        "fields_returned": "title, startTime, endTime, appointmentStatus, calendarId, address, notes, calLinks"
      }
    },
    {
      "id": "find-1",
      "type": "find",
      "label": "Find Contact",
      "position": { "x": 300, "y": 350 },
      "config": {
        "lookup_field": "lead_id",
        "lookup_value": "{{trigger.Lead_ID}}"
      }
    },
    {
      "id": "condition-1",
      "type": "condition",
      "label": "Lead Exists?",
      "position": { "x": 300, "y": 500 },
      "config": {
        "condition": "lead_found",
        "yes_label": "Existing Lead",
        "no_label": "New Lead"
      }
    },
    {
      "id": "action-existing",
      "type": "action",
      "label": "Existing Lead",
      "position": { "x": 480, "y": 650 },
      "config": {
        "action_type": "log",
        "message": "Lead found: {{find.lead_id}} — proceed with booking sync"
      }
    },
    {
      "id": "action-create",
      "type": "action",
      "label": "Create Lead",
      "position": { "x": 120, "y": 650 },
      "config": {
        "action_type": "create_contact",
        "fields": {
          "lead_id": "{{trigger.Lead_ID}}",
          "name": "{{trigger.Name}}"
        }
      }
    },
    {
      "id": "action-create-booking",
      "type": "action",
      "label": "Create Booking",
      "position": { "x": 300, "y": 800 },
      "config": {
        "action_type": "insert",
        "table": "bookings",
        "description": "Insert booking record with campaign attribution and appointment details from GHL",
        "fields": {
          "client_id": "{{client_id}}",
          "lead_id": "{{find.lead_id}}",
          "ghl_booking_id": "{{trigger.Booking_ID}}",
          "ghl_contact_id": "{{trigger.Lead_ID}}",
          "title": "{{appointment.title}}",
          "start_time": "{{appointment.startTime}}",
          "end_time": "{{appointment.endTime}}",
          "status": "{{appointment.appointmentStatus}}",
          "location": "{{appointment.address}}",
          "notes": "{{appointment.notes}}",
          "calendar_id": "{{appointment.calendarId}}",
          "cancellation_link": "{{appointment.calLinks.cancellationLink}}",
          "reschedule_link": "{{appointment.calLinks.rescheduleLink}}",
          "campaign_id": "{{most_recent_campaign_id || null}}"
        }
      }
    }
  ],
  "edges": [
    { "source": "trigger-1", "target": "action-fetch-appt" },
    { "source": "action-fetch-appt", "target": "find-1" },
    { "source": "find-1", "target": "condition-1" },
    { "source": "condition-1", "target": "action-create", "label": "No" },
    { "source": "condition-1", "target": "action-existing", "label": "Yes" },
    { "source": "action-create", "target": "action-create-booking" },
    { "source": "action-existing", "target": "action-create-booking" }
  ]
}
